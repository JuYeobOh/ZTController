# ============================================================
# ZT Controller 환경변수 예시
# 이 파일을 .env로 복사 후 값을 수정하세요.
#   cp .env.example .env
# ============================================================

# ── DB 설정 ─────────────────────────────────────────────────
# SQLite (개발/로컬)
CONTROLLER_DB_URL=sqlite:///./controller.db

# PostgreSQL (운영)
# CONTROLLER_DB_URL=postgresql://ztuser:strongpassword@db-host:5432/ztcontroller

# ── 보안 ────────────────────────────────────────────────────
# 토큰 인증은 사용하지 않는다.
# Controller는 SG/NACL로 직원망 VPC CIDR에서만 접근 가능하도록 제한된다 (네트워크 격리).
# 이전 CONTROLLER_API_TOKEN은 제거됨.

# ── 시간대 ──────────────────────────────────────────────────
CONTROLLER_TIMEZONE=Asia/Seoul

# ── Daily Plan 자동 생성 시각 (24시간제) ──────────────────────
# 매일 이 시각에 당일 plan을 생성합니다 (현재는 스크립트/API 수동 트리거)
DAILY_PLAN_GENERATION_HOUR=6

# ── Seed 파일 경로 ───────────────────────────────────────────
# 앱 실행 디렉토리(controller/) 기준 상대 경로
TASK_SEED_FILE=./config/tasks.yaml
EMPLOYEE_SEED_FILE=./config/employees.yaml
LOCATION_SEED_FILE=./config/locations.yaml
