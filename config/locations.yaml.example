# locations.yaml 형식 예시
# 이 파일을 locations.yaml로 복사 후 수정하세요.
#
# 필수 필드:
#   location_id : 위치 고유 ID (employees.yaml의 home_location_id와 일치해야 함)
#
# 선택 필드:
#   vpc_name    : AWS VPC 이름
#   subnet_name : AWS Subnet 이름
#   description : 설명
#
# Location 종류:
#   - Enterprise / Branch 사무실: 직원의 home_location
#   - outdoor-cafe-*: 야외 카페 (30% 확률 dispatch 대상)

locations:

  # ── Enterprise 본사 ───────────────────────────────────────────────────────
  - location_id: enterprise-hr
    vpc_name: enterprise-vpc
    subnet_name: hr-subnet
    description: Enterprise HQ - HR Department

  - location_id: enterprise-sales
    vpc_name: enterprise-vpc
    subnet_name: sales-subnet
    description: Enterprise HQ - Sales Department

  - location_id: enterprise-finance
    vpc_name: enterprise-vpc
    subnet_name: finance-subnet
    description: Enterprise HQ - Finance Department

  # ── Branch 사무소 ─────────────────────────────────────────────────────────
  - location_id: branch-dev
    vpc_name: branch-vpc
    subnet_name: dev-subnet
    description: Branch Office - Development Team

  - location_id: branch-it
    vpc_name: branch-vpc
    subnet_name: it-subnet
    description: Branch Office - IT Team

  # ── 야외 카페 (Cafe VPC) ──────────────────────────────────────────────────
  # 각 Cafe VPC는 매일 독립적으로 30% 확률로 야외 근무 발생
  # outdoor-cafe-* 형식의 location_id를 사용해야 카페 dispatch 로직이 동작함
  - location_id: outdoor-cafe-1
    vpc_name: cafe-vpc-1
    subnet_name: cafe-1-subnet
    description: Outdoor Cafe 1 (Public Network)

  - location_id: outdoor-cafe-2
    vpc_name: cafe-vpc-2
    subnet_name: cafe-2-subnet
    description: Outdoor Cafe 2 (Public Network)
